# ── Provider Wallet ──
PRIVATE_KEY=0x...
WALLET_PASSWORD=your-secure-password
NETWORK=bsc-testnet               # bsc-testnet | bsc-mainnet

# ── Agent Identity ──
AGENT_NAME=liquidity-skill-agent
AGENT_DESCRIPTION="BSC liquidity depth analyzer, rug-pull risk scorer, and MEV sandwich checker"

# ── ERC-8183 Protocol ──
ERC8183_SERVICE_PRICE=500000000000000000      # 0.5 U (18 decimals)
ERC8183_AGENT_URL=http://localhost:8010/erc8183
ERC8183_FUNDED_POLL_INTERVAL=15
ERC8183_NEGOTIATE_RATE_LIMIT=60
ERC8183_NEGOTIATE_RATE_WINDOW=60

# ── A2A Server ──
A2A_BASE_URL=http://localhost:8010
PORT=8010

# ── RPC (optional — uses public RPC by default) ──
# BSC_RPC_URL=https://bsc-dataseed.binance.org/
